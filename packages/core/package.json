{
  "name": "@a11y-guard/core",
  "version": "1.0.0",
  "description": "Core rule engine and compliance mappings for a11y-guard",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "htmlparser2": "^9.1.0",
    "domhandler": "^5.0.3",
    "domutils": "^3.1.0",
    "css-select": "^5.1.0",
    "wcag-contrast": "^3.0.0",
    "@babel/parser": "^7.24.0"
  },
  "devDependencies": {
    "@babel/types": "^7.24.0",
    "tsup": "^8.0.0",
    "vitest": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
