  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/Zunaib/a11y-guard.git", "directory": "packages/cli" },
